# StreakSync environment configuration
#
# 1. Create a free project at https://supabase.com/dashboard
# 2. Open Project Settings -> API and copy the two values below
# 3. Copy this file to `.env` (never commit `.env`)
#
# EXPO_PUBLIC_* variables are inlined into the app bundle at build time,
# so changing them requires restarting the Expo dev server.

# Project URL (Settings -> API -> Project URL)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public API key (Settings -> API -> Project API keys -> anon public).
# Safe to embed in the client: Row Level Security enforces all access control.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
